# ============================================================
# MON DASHBOARD — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- Steam ---
STEAM_API_KEY=92CCB5598FD91A8FFA8D2E051194C175
STEAM_ID=76561198286362838

# --- Anthropic / Claude Haiku 4.5 ---
# Ajouter la clé quand disponible. Plafond : 3€/mois
ANTHROPIC_API_KEY=
# Seuil de blocage en USD (2.50 $ ≈ ~2.30 €)
ANTHROPIC_MONTHLY_LIMIT_USD=2.50

# --- Gmail OAuth2 ---
# 1. Créer un projet sur https://console.cloud.google.com
# 2. Activer l'API Gmail
# 3. Créer des identifiants OAuth2 (type : Application de bureau)
# 4. Télécharger credentials.json et placer dans server/
GMAIL_USER=matthieu1.pinceel@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/oauth2callback
GMAIL_REFRESH_TOKEN=
# Chemin vers le fichier token stocké localement
GMAIL_TOKEN_PATH=server/gmail_token.json

# --- Base de données SQLite ---
DB_PATH=server/db/database.sqlite

# --- Scraping ---
# Délai entre requêtes (ms) pour éviter les bans
SCRAPE_DELAY_MS=1500
# User-Agent simulant un navigateur réel
SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# --- Pokémon TCG API ---
# Gratuit sans clé, mais une clé donne plus de quotas
# https://pokemontcg.io/
POKEMON_TCG_API_KEY=

# --- Lorcana (Lorcast) ---
# API open source, pas de clé requise
LORCANA_API_BASE=https://api.lorcast.com/v0

# --- Alertes / emails ---
# Email de destination pour les alertes (peut différer du compte Gmail)
ALERT_EMAIL=matthieu1.pinceel@gmail.com

# --- Cron schedules (format cron) ---
# Scraping promos nocturne (2h30 du matin)
CRON_SCRAPE_PROMOS=30 2 * * *
# Scan Gmail quotidien (7h00)
CRON_GMAIL_SCAN=0 7 * * *
# Vérification alertes prix (3h00)
CRON_PRICE_ALERTS=0 3 * * *
# Résumé hebdomadaire Claude Haiku (lundi 8h00)
CRON_WEEKLY_SUMMARY=0 8 * * 1
# Historique prix Cardmarket (3h30)
CRON_PRICE_HISTORY=30 3 * * *

# --- Logs ---
LOG_LEVEL=info
LOG_FILE=server/logs/app.log
